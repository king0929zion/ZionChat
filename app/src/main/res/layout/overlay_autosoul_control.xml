<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/autosoulOverlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_autosoul_float"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <View
        android:id="@+id/autosoulStatusDot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_autosoul_status_dot" />

    <TextView
        android:id="@+id/autosoulStatusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#F2FFFFFF"
        android:textSize="15sp"
        android:text="等待任务..." />

    <FrameLayout
        android:id="@+id/autosoulActionButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_autosoul_action">

        <ImageView
            android:id="@+id/autosoulStopIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_autosoul_stop"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/autosoulSendIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_autosoul_send"
            android:visibility="gone"
            android:contentDescription="@null" />
    </FrameLayout>

</LinearLayout>
